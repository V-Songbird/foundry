{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.py\"",
            "commandWindows": "python \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\session-start.py\"",
            "timeout": 5,
            "statusMessage": "Loading Relay..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/user-prompt-submit.py\"",
            "commandWindows": "python \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\user-prompt-submit.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Agent|Workflow)$",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use.py\"",
            "commandWindows": "python \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\post-tool-use.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/stop.py\"",
            "commandWindows": "python \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\stop.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
