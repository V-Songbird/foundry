{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^(Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/guard-roadmap-edit.js\"",
            "commandWindows": "node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\guard-roadmap-edit.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Bash|PowerShell)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/post-commit.js\"",
            "commandWindows": "node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\post-commit.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "^(Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/run-tests-on-edit.js\"",
            "commandWindows": "node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\run-tests-on-edit.js\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
